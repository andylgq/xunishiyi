##############################################################################
#                        SECURITY WARNING                                     #
#                                                                            #
#  DO NOT use these default values in production!                            #
#  All secrets MUST be replaced with long, random strings.                   #
#  Failure to do so will compromise the security of your application.        #
##############################################################################

# Database — leave empty to use embedded PGlite (zero-install) at ./.pglite-data
# Set to a real PostgreSQL/Supabase URL for production or Docker PG:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tryon
DATABASE_URL=

# App
APP_URL=http://localhost:3000
NODE_ENV=development

##############################################################################
#                        KEY SECRETS — MUST CHANGE IN PRODUCTION             #
##############################################################################

# Secret used to sign short-lived file-access JWTs
# Production: use `openssl rand -hex 32` or similar to generate a 32+ char secret
# WARNING: Using default values in production will allow attackers to forge file access tokens!
FILE_TOKEN_SECRET=<REPLACE_WITH_LONG_RANDOM_SECRET_MIN_16_CHARS>

# Secret required in X-Cron-Secret header for /api/cron/* endpoints
# Production: use `openssl rand -hex 16` to generate a random secret
# WARNING: Using default values in production will allow unauthorized cron execution!
CRON_SECRET=<REPLACE_WITH_RANDOM_SECRET>

##############################################################################
#                        ADMIN AUTH — MUST CHANGE IN PRODUCTION              #
##############################################################################

# Admin dashboard password (min 8 characters)
# Production: use a strong password
# WARNING: Using default values in production will allow unauthorized admin access!
ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# Secret for signing admin session cookies (min 32 characters)
# Production: use `openssl rand -hex 32` to generate
# WARNING: Using default values in production will allow session forgery!
ADMIN_SESSION_SECRET=<REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS>

# Admin session cookie name (can keep default, but recommended to change)
ADMIN_COOKIE_NAME=tryon_admin_session

# Anonymous session cookie name
ANON_COOKIE_NAME=tryon_anon_uid

# User auth session cookie name
AUTH_COOKIE_NAME=tryon_auth

##############################################################################
#                        TRY-ON PROVIDER CONFIG                              #
##############################################################################

# Try-on provider: "mock" (no key needed) | "volcano" (real 火山引擎) | "ark" (火山方舟 Seedream)
TRYON_PROVIDER=mock

# Volcano Engine (火山引擎智能视觉服务) virtual try-on
# Production: fill these with your actual Volcano Engine credentials
VOLC_ACCESS_KEY=<REPLACE_WITH_VOLC_ACCESS_KEY>
VOLC_SECRET_KEY=<REPLACE_WITH_VOLC_SECRET_KEY>
VOLC_REGION=cn-north-1
VOLC_SERVICE=cv
VOLC_ENDPOINT=https://visual.volcengineapi.com
VOLC_REQ_KEY=dressing_diffusionV2

# Volcano Ark Seedream API Key (for virtual try-on image generation)
# Production: fill with your actual Ark API key
ARK_API_KEY=<REPLACE_WITH_ARK_API_KEY>

##############################################################################
#                        QUOTA & LIMITS                                      #
##############################################################################

DAILY_QUOTA=5
MAX_UPLOAD_MB=10
MIN_SHORT_SIDE=512
RESULT_COUNT=3
TASK_TIMEOUT_SECONDS=120

##############################################################################
#                        TURNSTILE CAPTCHA                                   #
##############################################################################

# Cloudflare Turnstile site key (exposed to client, starts with NEXT_PUBLIC_)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<REPLACE_WITH_TURNSTILE_SITE_KEY>

# Cloudflare Turnstile secret key (server-side only, DO NOT expose to client)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=<REPLACE_WITH_TURNSTILE_SECRET_KEY>

##############################################################################
#                        CLOUDFLARE R2 STORAGE                               #
##############################################################################

# When all four values below are set, uploads and generated results are stored in R2.
# Otherwise the app falls back to local filesystem storage for development.
R2_ENDPOINT=<REPLACE_WITH_R2_ENDPOINT>
R2_ACCESS_KEY_ID=<REPLACE_WITH_R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<REPLACE_WITH_R2_SECRET_ACCESS_KEY>
R2_BUCKET_NAME=<REPLACE_WITH_R2_BUCKET_NAME>

# Optional: only needed if you later serve public R2 object URLs directly.
R2_PUBLIC_URL=<REPLACE_WITH_R2_PUBLIC_URL>
